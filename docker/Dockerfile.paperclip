FROM node:20-slim
RUN apt-get update && apt-get install -y --no-install-recommends curl && \
    rm -rf /var/lib/apt/lists/*

# Install Paperclip with built-in OpenClaw gateway adapter
RUN npm install -g paperclipai @paperclipai/adapter-openclaw-gateway

# Non-root user for embedded Postgres
RUN useradd -m -s /bin/bash paperclip && \
    mkdir -p /paperclip && chown -R paperclip:paperclip /paperclip
USER paperclip

VOLUME /paperclip
EXPOSE 3100

COPY --chown=paperclip:paperclip docker/paperclip-entrypoint.sh /usr/local/bin/entrypoint.sh
RUN chmod +x /usr/local/bin/entrypoint.sh
ENTRYPOINT ["/usr/local/bin/entrypoint.sh"]
