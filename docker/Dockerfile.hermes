FROM python:3.11-slim

RUN apt-get update && apt-get install -y --no-install-recommends \
    git curl nodejs npm && \
    rm -rf /var/lib/apt/lists/*

# Install uv for fast Python package management
RUN pip install --no-cache-dir uv

# Install Hermes Agent from source
RUN git clone --recurse-submodules https://github.com/NousResearch/hermes-agent.git /opt/hermes-agent && \
    cd /opt/hermes-agent && \
    uv pip install --system -e ".[all]"

# Install DuckDuckGo search (always available)
RUN pip install --no-cache-dir duckduckgo-search

# Install Agent-Reach tools
RUN pip install --no-cache-dir \
    "https://github.com/Panniantong/agent-reach/archive/main.zip"
RUN agent-reach install --env=auto --safe || true

VOLUME /data/agents
WORKDIR /data
ENTRYPOINT ["hermes"]
