FROM node:22-slim

RUN apt-get update && apt-get install -y --no-install-recommends \
    ca-certificates curl && \
    rm -rf /var/lib/apt/lists/*

# Install OpenClaw globally
RUN npm install -g openclaw@latest

# Create data directory
RUN mkdir -p /openclaw-data/.openclaw /openclaw-data/workspace && \
    chown -R 65534:65534 /openclaw-data

COPY docker/openclaw-entrypoint.sh /usr/local/bin/entrypoint.sh
RUN chmod +x /usr/local/bin/entrypoint.sh

ENV HOME=/openclaw-data
ENV OPENCLAW_STATE_DIR=/openclaw-data/.openclaw
ENV OPENCLAW_GATEWAY_PORT=42617

WORKDIR /openclaw-data
EXPOSE 42617

ENTRYPOINT ["/usr/local/bin/entrypoint.sh"]
CMD ["gateway", "run", "--port", "42617"]
