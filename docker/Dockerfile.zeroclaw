FROM debian:trixie-slim

RUN apt-get update && apt-get install -y --no-install-recommends \
    ca-certificates curl && \
    rm -rf /var/lib/apt/lists/*

# Download pre-built ZeroClaw binary from GitHub releases
RUN curl -fsSL https://github.com/openagen/zeroclaw/releases/download/v0.1.7-beta.1/zeroclaw-x86_64-unknown-linux-gnu.tar.gz \
    | tar -xzf - -C /usr/local/bin/ && \
    chmod +x /usr/local/bin/zeroclaw

# Create data directory
RUN mkdir -p /zeroclaw-data/.zeroclaw /zeroclaw-data/workspace && \
    chown -R 65534:65534 /zeroclaw-data

ENV ZEROCLAW_WORKSPACE=/zeroclaw-data/workspace
ENV HOME=/zeroclaw-data
ENV ZEROCLAW_GATEWAY_PORT=42617
ENV ZEROCLAW_ALLOW_PUBLIC_BIND=true

WORKDIR /zeroclaw-data
USER 65534:65534
EXPOSE 42617

ENTRYPOINT ["zeroclaw"]
CMD ["daemon"]
